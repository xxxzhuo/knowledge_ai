# ============== Database ==============
DATABASE_URL=postgresql://postgres:password@localhost:5432/knowledge_ai
DATABASE_ECHO=true

# ============== API ==============
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_TITLE="Semiconductor Knowledge AI"
API_VERSION="0.1.0"

# ============== LLM & Embedding ==============
# Embedding Service: openai or ollama
EMBEDDING_SERVICE=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=embeddinggemma
VECTOR_DIMENSION=768

# Ollama LLM Model (for RAG generation)
OLLAMA_LLM_MODEL=qwen2.5:7b

# OpenAI Configuration (when using OpenAI)
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_BATCH_SIZE=32

# ============== RAG Configuration ==============
# RAG LLM Type: openai or ollama
RAG_LLM_TYPE=ollama
RAG_TEMPERATURE=0.1
RAG_TOP_K=5
RAG_RERANKER_TYPE=simple  # simple, cross_encoder, hybrid
RAG_PROMPT_TYPE=default   # default, semiconductor, datasheet, conversational
RAG_MIN_SIMILARITY=0.3



# ============== Vector Store ==============
VECTOR_STORE_TYPE=milvus  # faiss, milvus, pgvector
MILVUS_HOST=localhost
MILVUS_PORT=19530
VECTOR_DIMENSION=768  # embeddinggemma: 768, text-embedding-3-large: 1536

# ============== Storage ==============
STORAGE_TYPE=s3  # s3, minio, local
S3_BUCKET=knowledge-ai
S3_ENDPOINT=https://s3.amazonaws.com
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx

# ============== Monitoring ==============
LANGSMITH_API_KEY=xxx
LANGSMITH_PROJECT_NAME=semiconductor-rag
PROMETHEUS_PORT=8001
LOG_LEVEL=INFO
